+func TestAudioOnlySessionMarksStreamStarted(t *testing.T) {
+	session := &MirrorSession{
+		videoWidth:     0,
+		videoHeight:    0,
+		firstFrameSent: make(chan struct{}),
+	}
+
+	if !session.isAudioOnly() {
+		t.Fatal("expected zero-sized stream to be treated as audio-only")
+	}
+
+	session.markStreamStarted("test audio-only session")
+	select {
+	case <-session.firstFrameSent:
+	case <-time.After(100 * time.Millisecond):
+		t.Fatal("audio-only session did not mark the AirPlay stream active")
+	}
+
+	session.markStreamStarted("second signal should be ignored")
+}
+
+func TestVideoSessionWaitsForFirstFrame(t *testing.T) {
+	session := &MirrorSession{
+		videoWidth:     1280,
+		videoHeight:    720,
+		firstFrameSent: make(chan struct{}),
+	}
+
+	if session.isAudioOnly() {
+		t.Fatal("expected non-zero dimensions to be treated as video mirroring")
+	}
+
+	select {
+	case <-session.firstFrameSent:
+		t.Fatal("video session should wait until the first frame is sent")
+	default:
+	}
+}
